# ============================================
# SSO Configuration (Backend)
# ============================================

# Enable/Disable SSO authentication
SSO_ENABLED=false

# OpenID Connect Configuration
SSO_OIDC_AUTHORITY=https://accounts.google.com
SSO_OIDC_CLIENT_ID=your-client-id
SSO_OIDC_CLIENT_SECRET=your-client-secret
SSO_OIDC_REDIRECT_URI=http://localhost:5173/auth/sso/callback
SSO_OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:5173/auth
SSO_OIDC_SCOPE=openid profile email phone
SSO_OIDC_RESPONSE_TYPE=code

# SSO Token Configuration
SSO_TOKEN_EXPIRY_SECONDS=3600

# SSO Providers (comma-separated: google,microsoft,apple,facebook,github)
SSO_PROVIDERS=google,microsoft,facebook,apple

# SSO User Claims to extract (comma-separated)
SSO_USER_CLAIMS=email,username,phoneNbr,roles,picture,sub,id

# ============================================
# Document AI Validation Configuration
# ============================================

# Enable auto-validation by AI without hyper admin review
# When false: AI analyzes docs but hyper admin must approve/reject
# When true: AI can auto-approve/reject if confidence >= threshold
DOC_AI_AUTO_VALIDATION=false

# Minimum AI confidence (0-1) to auto-approve/reject documents
# Lower values = more auto-decisions, higher values = more manual reviews
DOC_AI_CONFIDENCE_THRESHOLD=0.85

# AI/RAG API endpoint for document validation
# Example: https://your-ai-service.com/api/validate-document
DOC_AI_API_URL=

# AI API authentication key
DOC_AI_API_KEY=

# ============================================
# Email Configuration (for notifications)
# ============================================

# SMTP settings for sending email notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Email sender details
EMAIL_FROM_NAME=Byootdz
