VITE_API_URL=http://localhost:8095/api

# Auth method configuration
# Options: "email" | "phone" | "both"
VITE_AUTH_METHOD=both

# OTP mode configuration
# Options: "standalone" | "post-login"
# standalone: OTP can be used directly as a login method
# post-login: OTP can only be used after user logs in (for verification/2FA)
VITE_OTP_MODE=standalone

VITE_PASSWORD_HASH="1繕eXZfXThcyieXJ5xUSIPnA繕HJctDmSYDBJfaBmICKiTrSmDFNSEagQsXgEHtqamY1繕kjb7WamM1eE8PkUKCfCCJg繕XnFBpLYUlfYVdokWqWoawBG4R9g7EEJsngC8fiDAn26cKEFRGKEZRlf1y4tLKw9B0ZgfgYmmrhtZErGAKIATGIFANBVYCVO42B4"
VITE_PASSWORD_SALT=[0,5,2,3,4,1,4,7,8,9]

# Profile completion fields configuration
# Format: fieldName:fieldType:required (comma-separated)
# fieldTypes: input, textarea, select, checkbox, radio, file
VITE_PROFILE_FIELDS=firstName:input:true,lastName:input:true,avatar:file:false,dateOfBirth:input:false,address:textarea:false,gender:select:false
VITE_PROFILE_HIDDEN_FIELDS=createdAt,updatedAt

# SSO Configuration
# Enable/Disable SSO authentication
VITE_SSO_ENABLED=false

# OpenID Connect Configuration
VITE_SSO_OIDC_AUTHORITY=https://accounts.google.com
VITE_SSO_OIDC_CLIENT_ID=your-client-id
VITE_SSO_OIDC_REDIRECT_URI=http://localhost:5173/auth/sso/callback
VITE_SSO_OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:5173/auth
VITE_SSO_OIDC_SCOPE=openid profile email phone
VITE_SSO_OIDC_RESPONSE_TYPE=code

# SSO Token Configuration
VITE_SSO_TOKEN_EXPIRY_SECONDS=3600
VITE_SSO_TOKEN_RENEW_THRESHOLD_SECONDS=300
VITE_SSO_SILENT_RENEW=true

# SSO Providers (comma-separated: google,microsoft,apple,facebook,github)
VITE_SSO_PROVIDERS=google,microsoft

# SSO User Info Mapping (JSON mapping from OIDC claims to app user fields)
VITE_SSO_USER_CLAIMS=email,name,phone_number,roles,picture,sub